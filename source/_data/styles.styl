/* ========================================
   只想睡大觉 — typography 极简风格
   ======================================== */

/* === 全局 === */
body {
  background: #fff;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.main-inner {
  background: #fff;
  padding-top: 0;
}

.header {
  background: #fff;
}

::selection {
  background: #2e405b;
  color: #fff;
}

/* === 顶部导航 === */
.site-nav {
  border-bottom: none;
}

.menu .menu-item a {
  font-size: 0.85rem;
  letter-spacing: 2px;
  font-weight: 400;
  color: #999;
  transition: color 0.3s, background-color 0.3s;
  border-bottom: solid transparent 2px;
  padding: 0;
}

.menu .menu-item a:hover {
  color: #fff;
  background-color: #2e405b;
}

.menu .menu-item-active a {
  border-bottom: solid #2e405b 3px;
  background: none;
}

.site-title {
  font-weight: 700;
  letter-spacing: 6px;
}

.site-subtitle {
  letter-spacing: 2px;
  color: #aaa;
  font-weight: 300;
}

/* === 首页样式 === */
.homepage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  text-align: center;
  padding: 60px 24px;
}

.hp-hero {
  margin-bottom: 60px;
}

.hp-tagline {
  font-style: italic;
  font-size: 0.95rem;
  color: #bbb;
  letter-spacing: 1.5px;
  margin-bottom: 32px;
}

.hp-title {
  font-size: 2.8rem;
  font-weight: 300;
  letter-spacing: 12px;
  color: #2e405b;
  margin: 0 0 28px;
}

.hp-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28px;
  width: 60px;
  height: 1px;
  background: #ddd;
  position: relative;
}

.hp-divider-dot {
  width: 5px;
  height: 5px;
  background: #ccc;
  border-radius: 50%;
  position: absolute;
  top: -2px;
}

.hp-subtitle {
  font-size: 0.85rem;
  color: #bbb;
  letter-spacing: 4px;
  margin-bottom: 36px;
  font-weight: 300;
}

.hp-desc {
  font-size: 0.9rem;
  color: #aaa;
  line-height: 2.2;
  letter-spacing: 1px;
  font-weight: 300;
}

/* 首页链接区 */
.hp-links {
  display: flex;
  gap: 40px;
  margin-bottom: 72px;
}

.hp-link-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: #888;
  transition: color 0.3s, background-color 0.3s;
  border-bottom: solid transparent 2px;
}

.hp-link-item:hover {
  color: #fff;
  background-color: #2e405b;
}

.hp-link-icon {
  font-size: 1.4rem;
}

.hp-link-text {
  font-size: 0.78rem;
  letter-spacing: 3px;
}

/* 首页底部 */
.hp-footer-quote {
  text-align: center;
}

.hp-footer-quote p {
  font-style: italic;
  font-size: 0.82rem;
  color: #ccc;
  letter-spacing: 2px;
  margin: 0 0 8px;
}

.hp-footer-line {
  display: block;
  width: 30px;
  height: 1px;
  background: #ddd;
  margin: 12px auto;
}

.hp-footer-quote p:last-child {
  font-style: normal;
  font-size: 0.75rem;
  color: #ccc;
  letter-spacing: 3px;
}

/* === 文章正文排版 === */
.post-body {
  font-size: 1.0625rem;
  line-height: 2.1;
  color: #3a3835;
}

.post-body p {
  margin-bottom: 1.5rem;
}

.post-body h2 {
  font-size: 1.15rem;
  font-weight: 600;
  margin: 48px 0 18px;
  padding-left: 12px;
  border-left: 2px solid #2e405b;
  letter-spacing: 1px;
  color: #2e405b;
}

.post-body h3 {
  font-size: 1.05rem;
  font-weight: 500;
  margin: 36px 0 14px;
  letter-spacing: 0.5px;
  color: #2e405b;
}

.post-body blockquote {
  border-left: 2px solid #e0e0e0;
  padding: 6px 0 6px 22px;
  margin: 32px 0;
  color: #888;
  font-style: italic;
}

.post-body pre {
  background: #f5f5f5;
  color: #333;
  padding: 18px 20px;
  border-radius: 4px;
  font-size: 0.82rem;
  line-height: 1.8;
  margin: 32px 0;
  border: 1px solid #eee;
}

.post-body code {
  font-size: 0.88em;
  background: #f5f5f5;
  padding: 2px 6px;
  border-radius: 3px;
}

.post-body pre code {
  background: none;
  padding: 0;
  border-radius: 0;
}

.post-body a {
  color: #2e405b;
  text-decoration: none;
  border-bottom: solid #2e405b 2px;
  padding-bottom: 1px;
  transition: color 0.3s, background-color 0.3s;
}

.post-body a:hover {
  color: #fff;
  background-color: #2e405b;
  border-bottom: solid transparent 2px;
}

.post-body hr {
  border: none;
  height: 1px;
  background: linear-gradient(to right, transparent, #ddd, transparent);
  margin: 48px 0;
}

/* === 文章页标题 === */
.post-header .post-title {
  font-weight: 600;
  letter-spacing: 2px;
  font-size: 1.5rem;
  color: #2e405b;
}

.post-meta {
  color: #999;
  font-size: 14px;
}

/* === 标签按钮 === */
.tag-cloud a {
  border: 1px solid #e0e0e0;
  border-radius: 3px;
  padding: 3px 12px;
  color: #888;
  transition: all 0.2s ease;
  font-size: 0.8rem;
  letter-spacing: 1px;
}

.tag-cloud a:hover {
  color: #fff;
  background: #2e405b;
  border-color: #2e405b;
}

/* === 文章列表 /posts === */
.posts-expand .post {
  border-bottom: none;
  padding: 36px 0;
  margin-bottom: 4px;
  position: relative;
}

.posts-expand .post + .post::before {
  content: '';
  display: block;
  width: 40px;
  height: 1px;
  background: #e8e8e8;
  position: absolute;
  top: 0;
}

.posts-expand .post-title {
  font-weight: 600;
  letter-spacing: 2px;
  font-size: 1.25rem;
  margin-bottom: 10px;
}

.posts-expand .post-title a {
  color: #2e405b;
  border-bottom: none;
  transition: color 0.3s, background-color 0.3s;
}

.posts-expand .post-title a:hover {
  color: #fff;
  background-color: #2e405b;
}

.posts-expand .post-meta {
  color: #999;
  font-size: 14px;
  letter-spacing: 1px;
  margin-bottom: 16px;
}

.posts-expand .post-meta time {
  border-bottom: none;
}

.posts-expand .post-body {
  font-size: 0.95rem;
  line-height: 1.9;
  color: #666;
  margin-top: 14px;
}

.post-button {
  margin-top: 18px;
}

.post-button .btn {
  border: 1px solid #e0e0e0;
  color: #999;
  border-radius: 3px;
  font-size: 0.75rem;
  letter-spacing: 2px;
  padding: 6px 20px;
  transition: color 0.3s, background-color 0.3s, border-color 0.3s;
}

.post-button .btn:hover {
  color: #fff;
  background-color: #2e405b;
  border-color: #2e405b;
}

/* === 分页器 === */
.pagination .page-number.current {
  background: #2e405b;
  border-radius: 0;
}

/* === TOC 目录 === */
.post-toc {
  background: #fafaf9;
  border: 1px solid #eee;
  border-radius: 6px;
  padding: 24px 28px;
  margin-bottom: 36px;
  font-size: 15px;
  line-height: 2;
}

.post-toc .nav .nav-item .nav-link {
  color: #666;
  border-bottom: none;
  padding: 0;
}

.post-toc .nav .nav-item .nav-link:hover {
  color: #2e405b;
  background: transparent;
}

.post-toc .nav .active .nav-link {
  color: #2e405b;
  font-weight: 600;
}

/* === 侧边栏 === */
.sidebar-inner {
  background: #fff;
}

.sidebar-nav .sidebar-nav-active {
  color: #2e405b;
}

.site-overview-title {
  font-weight: 600;
  color: #2e405b;
}

/* === Gitalk === */
.gt-container .gt-header-textarea {
  background: #fff !important;
}

/* === 响应式 === */
@media (max-width: 768px) {
  .hp-title {
    font-size: 2rem;
    letter-spacing: 8px;
  }

  .hp-links {
    gap: 28px;
  }

  .posts-expand .post {
    padding: 24px 0;
  }

  .posts-expand .post-title {
    font-size: 1.1rem;
    letter-spacing: 1px;
  }

  .post-body {
    font-size: 0.95rem;
  }

  .post-body h2 {
    font-size: 1.08rem;
  }

  .post-header .post-title {
    font-size: 1.3rem;
  }
}
