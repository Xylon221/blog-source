/* ========================================
   只想睡大觉 — 极简白底
   ======================================== */

$accent        = #2e405b;
$accent-hover  = #1a2a3d;

/* === 全局 === */
body {
  background: #fff;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.main-inner {
  background: #fff;
  padding-top: 20px;
}

.header {
  background: #fff;
}

::selection {
  background: $accent;
  color: #fff;
}

/* === 顶部导航 === */
.site-nav {
  border-bottom: none;
}

.menu .menu-item a {
  font-size: 0.85rem;
  letter-spacing: 2px;
  font-weight: 400;
  color: #999;
  transition: color .3s, background-color .3s;
  padding: 4px 12px;
  border-radius: 2px;
}

.menu .menu-item a:hover {
  color: #fff;
  background-color: $accent;
}

.menu .menu-item-active a {
  color: $accent;
  background: none;
  border-bottom: solid $accent 2px;
  border-radius: 0;
}

.site-title {
  font-weight: 700;
  letter-spacing: 5px;
  color: $accent;
}

.site-subtitle {
  letter-spacing: 2px;
  color: #aaa;
  font-weight: 300;
}

/* === 首页样式 === */
.homepage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  text-align: center;
  padding: 60px 24px;
}

.hp-hero {
  margin-bottom: 60px;
}

.hp-tagline {
  font-style: italic;
  font-size: 0.95rem;
  color: #bbb;
  letter-spacing: 1.5px;
  margin-bottom: 32px;
}

.hp-title {
  font-size: 2.8rem;
  font-weight: 300;
  letter-spacing: 12px;
  color: $accent;
  margin: 0 0 28px;
}

.hp-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28px;
  width: 60px;
  height: 1px;
  background: #ddd;
  position: relative;
}

.hp-divider-dot {
  width: 5px;
  height: 5px;
  background: #ccc;
  border-radius: 50%;
  position: absolute;
  top: -2px;
}

.hp-subtitle {
  font-size: 0.85rem;
  color: #bbb;
  letter-spacing: 4px;
  margin-bottom: 36px;
  font-weight: 300;
}

.hp-desc {
  font-size: 0.9rem;
  color: #aaa;
  line-height: 2.2;
  letter-spacing: 1px;
  font-weight: 300;
}

/* 首页链接区 */
.hp-links {
  display: flex;
  gap: 40px;
  margin-bottom: 72px;
}

.hp-link-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: #888;
  border-radius: 4px;
  padding: 10px 20px;
  transition: all .3s ease;
}

.hp-link-item:hover {
  color: #fff;
  background-color: $accent;
}

.hp-link-icon {
  font-size: 1.4rem;
}

.hp-link-text {
  font-size: 0.78rem;
  letter-spacing: 3px;
}

/* 首页底部 */
.hp-footer-quote {
  text-align: center;
}

.hp-footer-quote p {
  font-style: italic;
  font-size: 0.82rem;
  color: #ccc;
  letter-spacing: 2px;
  margin: 0 0 8px;
}

.hp-footer-line {
  display: block;
  width: 30px;
  height: 1px;
  background: #ddd;
  margin: 12px auto;
}

.hp-footer-quote p:last-child {
  font-style: normal;
  font-size: 0.75rem;
  color: #ccc;
  letter-spacing: 3px;
}

/* === 文章列表 /posts === */
.posts-expand .post {
  border-bottom: none;
  padding: 36px 0;
  margin-bottom: 4px;
  position: relative;
}

.posts-expand .post + .post::before {
  content: '';
  display: block;
  width: 40px;
  height: 1px;
  background: #e8e8e8;
  position: absolute;
  top: 0;
}

.posts-expand .post-title {
  font-weight: 600;
  letter-spacing: 2px;
  font-size: 1.25rem;
  margin-bottom: 10px;
}

.posts-expand .post-title a {
  color: $accent;
  border-bottom: none;
  transition: color .3s, background-color .3s;
}

.posts-expand .post-title a:hover {
  color: #fff;
  background-color: $accent;
}

.posts-expand .post-meta {
  color: #999;
  font-size: 13px;
  letter-spacing: 1px;
  margin-bottom: 16px;
}

.posts-expand .post-meta time {
  border-bottom: none;
}

.posts-expand .post-body {
  font-size: 0.95rem;
  line-height: 1.9;
  color: #666;
  margin-top: 14px;
}

.post-button {
  margin-top: 18px;
}

.post-button .btn {
  border: 1px solid #ddd;
  color: #999;
  border-radius: 3px;
  font-size: 0.78rem;
  letter-spacing: 2px;
  padding: 7px 22px;
  transition: all .3s ease;
  background: transparent;
}

.post-button .btn:hover {
  color: #fff;
  background-color: $accent;
  border-color: $accent;
}

/* === 文章正文排版 === */
.post-body {
  font-size: 1.0625rem;
  line-height: 2.1;
  color: #3a3835;
}

.post-body p {
  margin-bottom: 1.5rem;
}

.post-body h2 {
  font-size: 1.15rem;
  font-weight: 600;
  margin: 48px 0 18px;
  padding-left: 12px;
  border-left: 2px solid $accent;
  letter-spacing: 1px;
  color: $accent;
}

.post-body h3 {
  font-size: 1.05rem;
  font-weight: 500;
  margin: 36px 0 14px;
  letter-spacing: 0.5px;
  color: $accent;
}

.post-body blockquote {
  border-left: 2px solid #e0e0e0;
  padding: 6px 0 6px 22px;
  margin: 32px 0;
  color: #888;
  font-style: italic;
}

.post-body pre {
  background: #f5f5f5;
  color: #333;
  padding: 18px 20px;
  border-radius: 4px;
  font-size: 0.82rem;
  line-height: 1.8;
  margin: 32px 0;
  border: 1px solid #eee;
}

.post-body code {
  font-size: 0.88em;
  background: #f5f5f5;
  padding: 2px 6px;
  border-radius: 3px;
}

.post-body pre code {
  background: none;
  padding: 0;
  border-radius: 0;
}

.post-body a {
  color: $accent;
  text-decoration: none;
  border-bottom: solid $accent 2px;
  padding-bottom: 1px;
  transition: color .3s, background-color .3s;
}

.post-body a:hover {
  color: #fff;
  background-color: $accent;
  border-bottom-color: transparent;
}

.post-body hr {
  border: none;
  height: 1px;
  background: linear-gradient(to right, transparent, #ddd, transparent);
  margin: 48px 0;
}

.post-body img {
  border-radius: 4px;
  box-shadow: 0 2px 8px rgba(0,0,0,.06);
}

/* === 文章页标题 === */
.post-header .post-title {
  font-weight: 600;
  letter-spacing: 2px;
  font-size: 1.5rem;
  color: $accent;
}

.post-meta {
  color: #999;
  font-size: 14px;
}

/* === 标签按钮 === */
.tag-cloud a {
  border: 1px solid #e0e0e0;
  border-radius: 3px;
  padding: 3px 12px;
  color: #888;
  transition: all .2s ease;
  font-size: 0.8rem;
  letter-spacing: 1px;
}

.tag-cloud a:hover {
  color: #fff;
  background: $accent;
  border-color: $accent;
}

/* === 分页器 === */
.pagination .page-number.current {
  background: $accent;
  border-radius: 0;
}

/* === 侧边栏 TOC === */
.post-toc-wrap {
  max-height: none !important;
  overflow: visible !important;
}

.post-toc {
  background: #fafaf9;
  border: 1px solid #eee;
  border-radius: 6px;
  padding: 20px 24px;
  margin-bottom: 36px;
  font-size: 14px;
  line-height: 2;
  max-height: none;
  overflow: visible;
}

.post-toc ol {
  padding-left: 1.2em;
  margin: 0;
  list-style: decimal;
}

.post-toc ol ol {
  list-style: lower-alpha;
}

.post-toc .nav-item {
  white-space: normal !important;
  overflow: visible !important;
  text-overflow: unset !important;
}

.post-toc .nav-link {
  color: #666;
  border-bottom: none !important;
  padding: 1px 0;
  display: inline;
  word-break: break-all;
}

.post-toc .nav-link:hover {
  color: #fff;
  background-color: $accent;
}

.post-toc .active .nav-link {
  color: $accent;
  font-weight: 600;
  background: transparent !important;
}

/* === 侧边栏 === */
.sidebar-inner {
  background: #fff;
}

.sidebar-nav .sidebar-nav-active {
  color: $accent;
}

.site-overview-title {
  font-weight: 600;
  color: $accent;
}

.links-of-author-item a {
  border-radius: 3px;
  padding: 4px 10px;
  transition: all .25s;
}

.links-of-author-item a:hover {
  color: #fff !important;
  background: $accent !important;
}

/* === Gitalk === */
.gt-container .gt-header-textarea {
  background: #fff !important;
  border-radius: 4px !important;
}

/* === 图片圆角 === */
img {
  border-radius: 4px;
}

/* === 响应式 === */
@media (max-width: 768px) {
  .hp-title {
    font-size: 2rem;
    letter-spacing: 8px;
  }

  .hp-links {
    gap: 20px;
  }

  .posts-expand .post {
    padding: 24px 0;
  }

  .posts-expand .post-title {
    font-size: 1.1rem;
    letter-spacing: 1px;
  }

  .post-body {
    font-size: 0.95rem;
  }

  .post-body h2 {
    font-size: 1.08rem;
  }

  .post-header .post-title {
    font-size: 1.3rem;
  }
}
