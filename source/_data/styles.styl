/* ========================================
   且听风吟 — 极简白底
   ======================================== */

/* === 全局纯白 === */
body {
  background: #fff;
}

.main-inner {
  background: #fff;
  padding-top: 0;
}

.header {
  background: #fff;
}

/* 顶部导航更轻盈 */
.site-nav {
  border-bottom: none;
}

.menu .menu-item a {
  font-size: 0.85rem;
  letter-spacing: 2px;
  font-weight: 400;
  color: #888;
  transition: color 0.3s;
}

.menu .menu-item a:hover {
  color: #222;
  background: none;
}

.site-title {
  font-weight: 400;
  letter-spacing: 4px;
}

.site-subtitle {
  letter-spacing: 2px;
  color: #aaa;
  font-weight: 300;
}

/* === 首页样式 === */
.homepage {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  text-align: center;
  padding: 60px 24px;
}

.hp-hero {
  margin-bottom: 60px;
}

.hp-tagline {
  font-family: "Playfair Display", "Cormorant Garamond", Georgia, serif;
  font-style: italic;
  font-size: 0.95rem;
  color: #bbb;
  letter-spacing: 1.5px;
  margin-bottom: 32px;
}

.hp-title {
  font-size: 2.8rem;
  font-weight: 300;
  letter-spacing: 12px;
  color: #222;
  margin: 0 0 28px;
}

.hp-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 28px;
  width: 60px;
  height: 1px;
  background: #ddd;
  position: relative;
}

.hp-divider-dot {
  width: 5px;
  height: 5px;
  background: #ccc;
  border-radius: 50%;
  position: absolute;
  top: -2px;
}

.hp-subtitle {
  font-size: 0.85rem;
  color: #bbb;
  letter-spacing: 4px;
  margin-bottom: 36px;
  font-weight: 300;
}

.hp-desc {
  font-size: 0.9rem;
  color: #aaa;
  line-height: 2.2;
  letter-spacing: 1px;
  font-weight: 300;
}

/* 首页链接区 */
.hp-links {
  display: flex;
  gap: 40px;
  margin-bottom: 72px;
}

.hp-link-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: #888;
  transition: color 0.3s;
}

.hp-link-item:hover {
  color: #222;
}

.hp-link-icon {
  font-size: 1.4rem;
}

.hp-link-text {
  font-size: 0.78rem;
  letter-spacing: 3px;
}

/* 首页底部 */
.hp-footer-quote {
  text-align: center;
}

.hp-footer-quote p {
  font-family: "Playfair Display", "Cormorant Garamond", Georgia, serif;
  font-style: italic;
  font-size: 0.82rem;
  color: #ccc;
  letter-spacing: 2px;
  margin: 0 0 8px;
}

.hp-footer-line {
  display: block;
  width: 30px;
  height: 1px;
  background: #ddd;
  margin: 12px auto;
}

.hp-footer-quote p:last-child {
  font-family: "Noto Serif SC", serif;
  font-style: normal;
  font-size: 0.75rem;
  color: #ccc;
  letter-spacing: 3px;
}

/* === 隐藏首页不需要的元素 === */
.homepage + * {
  /* 首页隐藏侧边栏和页脚的多余元素 */
}

/* === 文章正文排版 === */
.post-body {
  font-size: 1.0625rem;
  line-height: 2.1;
  color: #3a3835;
}

.post-body p {
  text-indent: 2em;
  margin-bottom: 1.5rem;
}

.post-body p:first-of-type {
  text-indent: 0;
}

.post-body h2 {
  font-size: 1.15rem;
  font-weight: 500;
  margin: 48px 0 18px;
  padding-left: 12px;
  border-left: 2px solid #e0e0e0;
  letter-spacing: 1px;
}

.post-body h3 {
  font-size: 1.05rem;
  font-weight: 500;
  margin: 36px 0 14px;
  letter-spacing: 0.5px;
}

.post-body blockquote {
  border-left: 2px solid #e0e0e0;
  padding: 6px 0 6px 22px;
  margin: 32px 0;
  color: #888;
  font-style: italic;
  text-indent: 0;
}

.post-body blockquote p {
  text-indent: 0;
}

.post-body pre {
  background: #f5f5f5;
  color: #333;
  padding: 22px 24px;
  border-radius: 4px;
  font-size: 0.82rem;
  line-height: 1.8;
  margin: 32px 0;
  border: 1px solid #eee;
}

.post-body code {
  font-size: 0.88em;
  background: #f5f5f5;
  padding: 2px 6px;
  border-radius: 3px;
}

.post-body pre code {
  background: none;
  padding: 0;
  border-radius: 0;
}

.post-body p code {
  text-indent: 0;
}

.post-body a {
  color: #555;
  text-decoration: none;
  border-bottom: 1px solid #ddd;
  padding-bottom: 1px;
  transition: border-color 0.2s, color 0.2s;
}

.post-body a:hover {
  color: #222;
  border-bottom-color: #222;
}

.post-body ul, .post-body ol {
  text-indent: 0;
}

.post-body li {
  text-indent: 0;
  margin-bottom: 8px;
}

/* === 标签按钮 === */
.tag-cloud a {
  border: 1px solid #e0e0e0;
  border-radius: 3px;
  padding: 3px 12px;
  color: #888;
  transition: all 0.2s ease;
  font-size: 0.8rem;
  letter-spacing: 1px;
}

.tag-cloud a:hover {
  color: #222;
  border-color: #222;
  background: none;
}

/* === 文章列表 /posts === */
.posts-expand .post {
  border-bottom: 1px solid #f0f0f0;
  padding-bottom: 28px;
}

.posts-expand .post-title {
  font-weight: 400;
  letter-spacing: 2px;
}

.posts-expand .post-meta {
  color: #bbb;
  font-size: 0.8rem;
}

.post-button .btn {
  border: 1px solid #ddd;
  color: #888;
  border-radius: 3px;
  font-size: 0.78rem;
  letter-spacing: 1px;
  transition: all 0.3s;
}

.post-button .btn:hover {
  color: #222;
  border-color: #222;
  background: none;
}

/* === 分页器 === */
.pagination .page-number.current {
  background: #222;
  border-radius: 0;
}

/* === 侧边栏更简洁 === */
.sidebar-inner {
  background: #fff;
}

.sidebar-nav .sidebar-nav-active {
  color: #222;
}

/* === 响应式 === */
@media (max-width: 640px) {
  .hp-title {
    font-size: 2rem;
    letter-spacing: 8px;
  }

  .hp-links {
    gap: 28px;
  }

  .post-body {
    font-size: 0.95rem;
  }

  .post-body p {
    text-indent: 1.5em;
  }

  .post-body h2 {
    font-size: 1.08rem;
  }
}
